<!--  ReSharper disable Xaml.StaticResourceNotResolved  -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:customControls="using:CollapseLauncher.XAMLs.Theme.CustomControls"
                    xmlns:extension="using:CollapseLauncher.Extension">

    <Style TargetType="customControls:LayeredBackgroundImage">
        <Setter Property="SmokeBackground" Value="{ThemeResource LayeredBackgroundImageSmokeBackground}" />
        <Setter Property="SmokeOpacity" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="customControls:LayeredBackgroundImage">
                    <Grid x:Name="RootPanel">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="PlaceholderStates">
                                <VisualState x:Name="PlaceholderStateHidden">
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PlaceholderGrid"
                                                                       Storyboard.TargetProperty="Opacity">
                                            <SplineDoubleKeyFrame KeySpline="{StaticResource ControlFastOutSlowInKeySpline}"
                                                                  KeyTime="{StaticResource ControlFastAnimationDuration}"
                                                                  Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PlaceholderGrid"
                                                                       Storyboard.TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="{StaticResource ControlFastAnimationDuration}"
                                                                    Value="Collapsed" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <Grid x:Name="PlaceholderGrid"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />
                        <Grid x:Name="ElevateGrid"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Opacity="{ThemeResource LayeredBackgroundImageContentOpacity}"
                              extension:UIElementExtensions.IsTranslationEnabled="True">
                            <Grid x:Name="ParallaxGrid"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  extension:UIElementExtensions.IsTranslationEnabled="True">
                                <Grid x:Name="BackgroundGrid"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch" />
                            </Grid>
                        </Grid>
                        <Grid x:Name="ForegroundGrid"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Opacity="{TemplateBinding ForegroundOpacity}">
                            <Grid.OpacityTransition>
                                <ScalarTransition Duration="0:0:0.3" />
                            </Grid.OpacityTransition>
                        </Grid>
                        <Grid x:Name="SmokeGrid"
                              Background="{TemplateBinding SmokeBackground}"
                              Opacity="{TemplateBinding SmokeOpacity}">
                            <Grid.OpacityTransition>
                                <ScalarTransition Duration="0:0:0.3" />
                            </Grid.OpacityTransition>
                            <Grid.BackgroundTransition>
                                <BrushTransition Duration="0:0:0.2" />
                            </Grid.BackgroundTransition>
                        </Grid>
                        <!--  Solid backdrop shown only in High Contrast mode, replaces the game background image  -->
                        <Grid x:Name="HighContrastBackdrop"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="{ThemeResource SystemColorWindowColorBrush}"
                              Opacity="{ThemeResource LayeredBackgroundImageHighContrastBackdropOpacity}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>