<!--  ReSharper disable IdentifierTypo  -->
<!--  ReSharper disable UnusedMember.Local  -->
<!--  ReSharper disable Xaml.ConstructorWarning  -->
<Page x:Class="CollapseLauncher.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
      xmlns:animations="using:CommunityToolkit.WinUI.Animations"
      xmlns:backgroundManager="using:CollapseLauncher.GameManagement.ImageBackground"
      xmlns:behaviors="using:CommunityToolkit.WinUI.Behaviors"
      xmlns:c="using:CollapseLauncher.XAMLs.Theme.CustomControls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:extension="using:CollapseLauncher.Extension"
      xmlns:helper="using:CollapseLauncher.Helper"
      xmlns:hypTypes="using:CollapseLauncher.Helper.LauncherApiLoader.HoYoPlay"
      xmlns:imageex="using:ImageEx"
      xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
      xmlns:local="using:CollapseLauncher"
      xmlns:localWindowSize="using:CollapseLauncher.WindowSize"
      xmlns:lottie="using:CollapseLauncher.AnimatedVisuals.Lottie"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:pages="using:CollapseLauncher.Pages"
      xmlns:theme="using:CollapseLauncher.XAMLs.Theme"
      Loaded="Page_Loaded"
      NavigationCacheMode="Enabled"
      Unloaded="Page_Unloaded"
      mc:Ignorable="d">
    <Page.Resources>
        <pages:BooleanVisibilityConverter x:Key="BooleanVisibilityConverter" />
        <pages:InverseBooleanVisibilityConverter x:Key="InverseBooleanVisibilityConverter" />
        <pages:NullableVisibilityConverter x:Key="NullableVisibilityConverter" />
        <pages:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <pages:UrlToCachedImagePathConverter x:Key="UrlToCachedImagePathConverter" />
        <pages:FileSizeToStringLiteralConverter x:Key="FileSizeToStringLiteralConverter" />
        <pages:BooleanToOpacityConverter x:Key="BooleanToOpacityConverter" />
        <pages:PercentageValueConverter x:Key="PercentageValueConverter" />
        <pages:IsNumberEqualToBooleanConverter x:Key="IsNumberEqualToBooleanConverter" />
        <pages:InverseIsContainsAnyNumbersToBooleanConverter x:Key="InverseIsContainsAnyNumbersToBooleanConverter" />
        <pages:TimeSpanToTimeStampStringConverter x:Key="TimeSpanToTimeStampStringConverter" />
        <pages:TimeSpanToNumberMillisecondsConverter x:Key="TimeSpanToNumberMillisecondsConverter" />
        <pages:TimeSpanMoreThan15SecondsToVisibilityConverter x:Key="TimeSpanMoreThan15SecondsToVisibilityConverter" />
        <pages:FontPathLookupConverter x:Key="FontPathLookupConverter" />
        <c:IndexAddOneConverter x:Key="IndexAddOneConverter" />

        <MenuFlyout x:Key="BackgroundContextMenuFlyout"
                    Placement="Bottom"
                    ShouldConstrainToRootBounds="False">
            <MenuFlyoutItem Text="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_SaveCurrentBgText, Mode=OneWay}"
                            ToolTipService.Placement="Left"
                            ToolTipService.ToolTip="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_SaveCurrentBgTooltip, Mode=OneWay}">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE74E;" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutItem Text="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_SaveAllBgText, Mode=OneWay}"
                            ToolTipService.Placement="Left"
                            ToolTipService.ToolTip="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_SaveAllBgTooltip, Mode=OneWay}">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE78C;" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutSubItem DataContext="{x:Bind CurrentBackgroundManager, Mode=OneWay}"
                               Text="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_CopyFrameToClipboardParentText, Mode=OneWay}">
                <MenuFlyoutSubItem.Resources>
                    <backgroundManager:FrameToCopyType x:Key="CopyToClipboardForegroundOnly">Foreground</backgroundManager:FrameToCopyType>
                    <backgroundManager:FrameToCopyType x:Key="CopyToClipboardBackgroundOnly">Background</backgroundManager:FrameToCopyType>
                    <backgroundManager:FrameToCopyType x:Key="CopyToClipboardBoth">Both</backgroundManager:FrameToCopyType>
                </MenuFlyoutSubItem.Resources>
                <MenuFlyoutSubItem.Icon>
                    <FontIcon Glyph="&#xE77F;" />
                </MenuFlyoutSubItem.Icon>
                <MenuFlyoutItem Command="{x:Bind BackgroundImageContextMenuCopyImageToClipboardCommand}"
                                CommandParameter="{StaticResource CopyToClipboardForegroundOnly}"
                                IsEnabled="{Binding CurrentSelectedBackgroundHasOverlayImage, Mode=OneWay}"
                                Text="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_CopyFrameToClipboardOverlayText, Mode=OneWay}"
                                ToolTipService.Placement="Left"
                                ToolTipService.ToolTip="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_CopyFrameToClipboardOverlayTooltip, Mode=OneWay}" />
                <MenuFlyoutItem Command="{x:Bind BackgroundImageContextMenuCopyImageToClipboardCommand}"
                                CommandParameter="{StaticResource CopyToClipboardBackgroundOnly}"
                                Text="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_CopyFrameToClipboardBackgroundText, Mode=OneWay}"
                                ToolTipService.Placement="Left"
                                ToolTipService.ToolTip="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_CopyFrameToClipboardBackgroundTooltip, Mode=OneWay}" />
                <MenuFlyoutItem IsEnabled="{Binding CurrentSelectedBackgroundHasOverlayImage, Mode=OneWay}"
                                Text="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_CopyFrameToClipboardMergedText, Mode=OneWay}"
                                ToolTipService.Placement="Left"
                                ToolTipService.ToolTip="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_CopyFrameToClipboardMergedTooltip, Mode=OneWay}" />
            </MenuFlyoutSubItem>
            <MenuFlyoutSubItem DataContext="{x:Bind CurrentBackgroundManager, Mode=OneWay}"
                               Text="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_CopyUrlToClipboardParentText, Mode=OneWay}">
                <MenuFlyoutSubItem.Icon>
                    <FontIcon Glyph="&#xE77F;" />
                </MenuFlyoutSubItem.Icon>
                <MenuFlyoutItem Command="{x:Bind BackgroundImageContextMenuCopyUrlToClipboardCommand}"
                                CommandParameter="{Binding CurrentSelectedBackgroundContext.OriginOverlayImagePath, FallbackValue={x:Null}, Mode=OneWay}"
                                IsEnabled="{Binding CurrentSelectedBackgroundHasOverlayImage, Mode=OneWay}"
                                Text="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_CopyUrlToClipboardOverlayText, Mode=OneWay}"
                                ToolTipService.Placement="Left"
                                ToolTipService.ToolTip="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_CopyUrlToClipboardOverlayTooltip, Mode=OneWay}" />
                <MenuFlyoutItem Text="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_CopyUrlToClipboardBackgroundText, Mode=OneWay}"
                                ToolTipService.Placement="Left"
                                ToolTipService.ToolTip="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_CopyUrlToClipboardBackgroundTooltip, Mode=OneWay}" />
            </MenuFlyoutSubItem>
            <MenuFlyoutSeparator Margin="16,8" />
            <ToggleMenuFlyoutItem DataContext="{x:Bind CurrentBackgroundManager, Mode=OneWay}"
                                  IsChecked="{Binding GlobalBackgroundAudioEnabled, Mode=TwoWay}"
                                  Text="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_EnableAudioText, Mode=OneWay}"
                                  ToolTipService.Placement="Left"
                                  ToolTipService.ToolTip="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_EnableAudioTooltip, Mode=OneWay}">
                <ToggleMenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE8D6;" />
                </ToggleMenuFlyoutItem.Icon>
            </ToggleMenuFlyoutItem>
            <ToggleMenuFlyoutItem DataContext="{x:Bind CurrentBackgroundManager, Mode=OneWay}"
                                  IsChecked="{Binding GlobalKeepPlayVideoWhenWindowUnfocused, Mode=TwoWay}"
                                  Text="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_KeepPlayVideoOnUnfocusText, Mode=OneWay}"
                                  ToolTipService.Placement="Left"
                                  ToolTipService.ToolTip="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_KeepPlayVideoOnUnfocusTooltip, Mode=OneWay}">
                <ToggleMenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE786;" />
                </ToggleMenuFlyoutItem.Icon>
            </ToggleMenuFlyoutItem>
            <ToggleMenuFlyoutItem DataContext="{x:Bind CurrentBackgroundManager, Mode=OneWay}"
                                  IsChecked="{Binding GlobalIsBackgroundParallaxEffectEnabled, Mode=TwoWay}"
                                  Text="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_EnableParallaxText, Mode=OneWay}"
                                  ToolTipService.Placement="Left"
                                  ToolTipService.ToolTip="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_EnableParallaxTooltip, Mode=OneWay}">
                <ToggleMenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE7B3;" />
                </ToggleMenuFlyoutItem.Icon>
            </ToggleMenuFlyoutItem>
            <MenuFlyoutSubItem DataContext="{x:Bind CurrentBackgroundManager, Mode=OneWay}"
                               Text="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_ParallaxPixelShiftParentText, Mode=OneWay}">
                <RadioMenuFlyoutItem IsChecked="{Binding GlobalBackgroundParallaxPixelShift, ConverterParameter='2', Converter={StaticResource IsNumberEqualToBooleanConverter}, Mode=TwoWay}"
                                     Text="2px" />
                <RadioMenuFlyoutItem IsChecked="{Binding GlobalBackgroundParallaxPixelShift, ConverterParameter='4', Converter={StaticResource IsNumberEqualToBooleanConverter}, Mode=TwoWay}"
                                     Text="4px" />
                <RadioMenuFlyoutItem IsChecked="{Binding GlobalBackgroundParallaxPixelShift, ConverterParameter='8', Converter={StaticResource IsNumberEqualToBooleanConverter}, Mode=TwoWay}"
                                     Text="8px" />
                <MenuFlyoutSeparator />
                <RadioMenuFlyoutItem IsChecked="{Binding GlobalBackgroundParallaxPixelShift, ConverterParameter='2, 4, 8', Converter={StaticResource InverseIsContainsAnyNumbersToBooleanConverter}, Mode=OneWay}"
                                     Text="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_ParallaxPixelShiftCustomText, Mode=OneWay}"
                                     ToolTipService.Placement="Left"
                                     ToolTipService.ToolTip="{x:Bind helper:Locale.Current.Lang._HomePage.BgContextMenu_ParallaxPixelShiftCustomTooltip, Mode=OneWay}" />
            </MenuFlyoutSubItem>
        </MenuFlyout>
    </Page.Resources>
    <Grid x:Name="FrameGrid"
          Margin="32,8,32,32"
          HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="41" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{x:Bind localWindowSize:WindowSize.CurrentWindowSize.SidePanel1Width}" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid x:Name="BackgroundImageContextMenuGrid"
              Grid.Row="0"
              Grid.RowSpan="4"
              Grid.Column="0"
              Grid.ColumnSpan="2"
              Margin="-32"
              Background="Transparent"
              ContextFlyout="{StaticResource BackgroundContextMenuFlyout}"
              DataContext="{x:Bind CurrentBackgroundManager, Mode=OneWay}" />
        <Grid x:Name="ImageEventImgGrid"
              Grid.Row="{x:Bind CurrentBannerIconRow}"
              Grid.RowSpan="{x:Bind pages:HomePage.CurrentBannerIconRowSpan}"
              Grid.Column="{x:Bind CurrentBannerIconColumn}"
              Grid.ColumnSpan="{x:Bind pages:HomePage.CurrentBannerIconColumnSpan}"
              Height="{x:Bind CurrentBannerIconHeight}"
              Margin="{x:Bind CurrentBannerIconMargin}"
              HorizontalAlignment="{x:Bind CurrentBannerIconHorizontalAlign}"
              VerticalAlignment="{x:Bind CurrentBannerIconVerticalAlign}"
              Visibility="Collapsed">
            <Grid x:Name="ImageEventImgShadow" />
            <Image x:Name="ImageEventImg"
                   extension:UIElementExtensions.CursorType="Hand"
                   PointerPressed="ClickImageEventSpriteLink" />
        </Grid>
        <InfoBar x:Name="PreloadDialogBox"
                 Title=""
                 Grid.Row="0"
                 Grid.Column="0"
                 Grid.ColumnSpan="2"
                 MaxWidth="870"
                 Margin="0,16,48,-32"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Top"
                 Background="{ThemeResource InfoBarAnnouncementBrush}"
                 CornerRadius="12"
                 IsClosable="True"
                 IsOpen="False"
                 Opacity="0"
                 Severity="Informational"
                 Shadow="{ThemeResource SharedShadow}">
            <InfoBar.Content>
                <StackPanel Margin="0,-4,38,0"
                            Orientation="Vertical">
                    <Grid x:Name="ProgressPreStatusGrid"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Top"
                          Visibility="Collapsed">
                        <Grid.ChildrenTransitions>
                            <PopupThemeTransition />
                        </Grid.ChildrenTransitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0"
                              HorizontalAlignment="Stretch">
                            <StackPanel HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        Orientation="Vertical">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"
                                                Grid.ColumnSpan="2">
                                        <StackPanel HorizontalAlignment="Left"
                                                    Orientation="Horizontal">
                                            <TextBlock x:Name="ProgressPrePerFileStatusFooter"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Text="Downloading" />
                                        </StackPanel>
                                        <TextBlock x:Name="ProgressPreStatusFooter"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Text="{x:Bind helper:Locale.Current.Lang._Misc.SpeedPlaceholder, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Bottom"
                                                Orientation="Horizontal">
                                        <TextBlock FontSize="12"
                                                   FontWeight="Bold"
                                                   Text="{x:Bind ProgressPrePerFileBar.Value, Mode=OneWay}" />
                                        <TextBlock FontSize="12"
                                                   FontWeight="Bold"
                                                   Text="%" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Bottom">
                                        <TextBlock x:Name="ProgressPrePerFileStatusSubtitle"
                                                   HorizontalAlignment="Right"
                                                   FontSize="12"
                                                   Text="{x:Bind helper:Locale.Current.Lang._Misc.PerFromToPlaceholder, Mode=OneWay}" />
                                    </StackPanel>
                                </Grid>
                                <ProgressBar x:Name="ProgressPrePerFileBar"
                                             Margin="0,4,0,16"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Top"
                                             IsIndeterminate="True"
                                             Maximum="100"
                                             Value="0" />
                            </StackPanel>
                        </Grid>
                        <Grid Grid.Column="2"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Bottom">
                            <StackPanel HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        Orientation="Vertical">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"
                                                VerticalAlignment="Bottom">
                                        <TextBlock x:Name="ProgressPreStatusSubtitle"
                                                   HorizontalAlignment="Left"
                                                   FontSize="12"
                                                   Text="{x:Bind helper:Locale.Current.Lang._Misc.PerFromToPlaceholder, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Bottom"
                                                Orientation="Horizontal">
                                        <TextBlock FontSize="12"
                                                   FontWeight="Bold"
                                                   Text="{x:Bind ProgressPreBar.Value, Mode=OneWay}" />
                                        <TextBlock FontSize="12"
                                                   FontWeight="Bold"
                                                   Text="%" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock HorizontalAlignment="Right"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Text="{x:Bind helper:Locale.Current.Lang._Misc.TimeRemain, Mode=OneWay}" />
                                        <TextBlock x:Name="ProgressPreTimeLeft"
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Right"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Text="-" />
                                    </StackPanel>
                                </Grid>
                                <ProgressBar x:Name="ProgressPreBar"
                                             Margin="0,4,0,16"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Top"
                                             IsIndeterminate="True"
                                             Maximum="100"
                                             Value="0" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                    <Grid x:Name="ProgressPreSophonStatusGrid"
                          Visibility="Collapsed">
                        <Grid.ChildrenTransitions>
                            <PopupThemeTransition />
                        </Grid.ChildrenTransitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0"
                              HorizontalAlignment="Stretch">
                            <StackPanel HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        Orientation="Vertical">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"
                                                Grid.ColumnSpan="2">
                                        <StackPanel HorizontalAlignment="Left"
                                                    Orientation="Horizontal">
                                            <TextBlock FontSize="12"
                                                       FontWeight="Bold"
                                                       Text="{x:Bind ProgressPrePerFileStatusFooter.Text, Mode=OneWay}" />
                                        </StackPanel>
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Text="{x:Bind ProgressPreStatusFooter.Text, Mode=OneWay}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                        <Grid Grid.Row="0"
                              Grid.Column="0"
                              Grid.ColumnSpan="3"
                              Margin="0,0,0,8"
                              HorizontalAlignment="Stretch"
                              ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom">
                                <TextBlock HorizontalAlignment="Right"
                                           FontSize="12"
                                           Text="{x:Bind ProgressPreStatusSubtitle.Text, Mode=OneWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        Orientation="Horizontal">
                                <TextBlock FontSize="12"
                                           FontWeight="Bold"
                                           Text="{x:Bind ProgressPreBar.Value, Mode=OneWay}" />
                                <TextBlock FontSize="12"
                                           FontWeight="Bold"
                                           Text="%" />
                            </StackPanel>
                        </Grid>
                        <Grid Grid.Row="0"
                              Grid.Column="2"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Bottom">
                            <StackPanel HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        Orientation="Vertical">
                                <Grid Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock HorizontalAlignment="Right"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Text="{x:Bind helper:Locale.Current.Lang._Misc.TimeRemain, Mode=OneWay}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   HorizontalAlignment="Right"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Text="{x:Bind ProgressPreTimeLeft.Text, Mode=OneWay}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                        <ProgressBar Grid.Row="1"
                                     Grid.Column="0"
                                     Grid.ColumnSpan="3"
                                     Margin="0,8,0,24"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Bottom"
                                     IsIndeterminate="{x:Bind ProgressPreBar.IsIndeterminate, Mode=OneWay}"
                                     Maximum="{x:Bind ProgressPreBar.Maximum, Mode=OneWay}"
                                     Value="{x:Bind ProgressPreBar.Value, Mode=OneWay}" />
                    </Grid>
                    <Grid x:Name="ProgressPreButtonGrid"
                          Margin="0,-8,0,16"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Top"
                          Visibility="Collapsed">
                        <Grid.ChildrenTransitions>
                            <PopupThemeTransition />
                        </Grid.ChildrenTransitions>
                        <Grid x:Name="DownloadModeLabelPreload"
                              Padding="8,2"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top"
                              Background="{ThemeResource AccentColorBrush}"
                              CornerRadius="8"
                              Shadow="{ThemeResource SharedShadow}"
                              Translation="0,0,16"
                              Visibility="Collapsed">
                            <TextBlock x:Name="DownloadModeLabelPreloadText"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                                       HorizontalTextAlignment="Center"
                                       Text="" />
                        </Grid>
                        <Button x:Name="PauseDownloadPreBtn"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Click="CancelInstallationProcedure"
                                CornerRadius="16"
                                Shadow="{ThemeResource SharedShadow}"
                                Style="{ThemeResource AcrylicButtonStyle}"
                                Translation="0,0,8"
                                Visibility="Visible">
                            <Button.Content>
                                <Grid Margin="8,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Margin="0,-2,16,0"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               FontWeight="Medium"
                                               HorizontalTextAlignment="Left"
                                               Text="{x:Bind helper:Locale.Current.Lang._HomePage.PauseDownloadBtn, Mode=OneWay}" />
                                    <FontIcon Grid.Column="1"
                                              HorizontalAlignment="Right"
                                              FontFamily="{ThemeResource FontAwesomeSolid}"
                                              FontSize="14"
                                              Glyph="" />
                                </Grid>
                            </Button.Content>
                        </Button>
                        <Button x:Name="ResumeDownloadPreBtn"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Click="PredownloadDialog"
                                CornerRadius="16"
                                Shadow="{ThemeResource SharedShadow}"
                                Style="{ThemeResource AcrylicButtonStyle}"
                                Translation="0,0,8"
                                Visibility="Collapsed">
                            <Button.Content>
                                <Grid Margin="8,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Margin="0,-2,16,0"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               FontWeight="Medium"
                                               HorizontalTextAlignment="Left"
                                               Text="{x:Bind helper:Locale.Current.Lang._HomePage.ResumeDownloadBtn, Mode=OneWay}" />
                                    <FontIcon Grid.Column="1"
                                              HorizontalAlignment="Right"
                                              FontFamily="{ThemeResource FontAwesomeSolid}"
                                              FontSize="14"
                                              Glyph="" />
                                </Grid>
                            </Button.Content>
                        </Button>
                    </Grid>
                </StackPanel>
            </InfoBar.Content>
            <InfoBar.ActionButton>
                <Button x:Name="DownloadPreBtn"
                        Margin="0,0,-16,0"
                        HorizontalAlignment="Right"
                        HorizontalContentAlignment="Stretch"
                        Click="PredownloadDialog"
                        CornerRadius="16"
                        Shadow="{ThemeResource SharedShadow}"
                        Style="{ThemeResource AcrylicSemiButtonStyle}"
                        Translation="0,0,8"
                        Visibility="Visible">
                    <Button.Content>
                        <Grid Margin="8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Margin="0,-2,16,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       FontWeight="Medium"
                                       HorizontalTextAlignment="Left"
                                       Text="{x:Bind helper:Locale.Current.Lang._HomePage.DownloadBtn, Mode=OneWay}" />
                            <FontIcon Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      FontFamily="{ThemeResource FontAwesomeSolid}"
                                      FontSize="14"
                                      Glyph="" />
                        </Grid>
                    </Button.Content>
                </Button>
            </InfoBar.ActionButton>
        </InfoBar>
        <c:NonFaultyGrid x:Name="SocMedPanelAndWpfButtonGrid"
                         Grid.Row="0"
                         Grid.RowSpan="2"
                         Grid.Column="1"
                         Margin="0,0,-24,16"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Center"
                         RowSpacing="16">
            <c:NonFaultyGrid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </c:NonFaultyGrid.RowDefinitions>
            <c:NonFaultyGrid.ChildrenTransitions>
                <ContentThemeTransition />
            </c:NonFaultyGrid.ChildrenTransitions>
            <Grid x:Name="SocMedPanel"
                  Grid.Row="0"
                  Padding="4,4"
                  Background="{ThemeResource SocMedPanelAcrylicBrush}"
                  CornerRadius="16"
                  Shadow="{ThemeResource SharedShadow}"
                  Translation="0,0,32">
                <ScrollViewer x:Name="SocMedPanelScrollView"
                              CanContentRenderOutsideBounds="True"
                              VerticalScrollBarVisibility="Hidden">
                    <ItemsControl IsTabStop="False"
                                  ItemsSource="{x:Bind pages:HomePage.GameSocialMediaData}"
                                  TabFocusNavigation="Once"
                                  UseSystemFocusVisuals="True"
                                  XYFocusKeyboardNavigation="Enabled">
                        <ItemsControl.ItemContainerTransitions>
                            <ContentThemeTransition />
                        </ItemsControl.ItemContainerTransitions>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="hypTypes:HypLauncherSocialMediaContentData">
                                <Button x:Name="SocMedButton"
                                        MinWidth="48"
                                        MinHeight="48"
                                        MaxWidth="48"
                                        MaxHeight="48"
                                        Margin="4,4"
                                        Padding="8"
                                        extension:UIElementExtensions.CursorType="Hand"
                                        BorderThickness="0"
                                        Click="OpenSocMedLink"
                                        Content="{Binding}"
                                        CornerRadius="12"
                                        FlyoutBase.AttachedFlyout="{Binding ElementName=SocMedFlyout}"
                                        PointerExited="FadeOutSocMedButton"
                                        Style="{ThemeResource SocialMediaButtonStyle}"
                                        Tag="{Binding Icon.ClickLink, FallbackValue={x:Null}}">
                                    <ToolTipService.ToolTip>
                                        <ToolTip Opened="ShowSocMedFlyout"
                                                 Tag="{Binding ElementName=SocMedButton}"
                                                 Visibility="Collapsed" />
                                    </ToolTipService.ToolTip>
                                    <Button.Flyout>
                                        <Flyout x:Name="SocMedFlyout"
                                                OverlayInputPassThroughElement="{Binding ElementName=SocMedPanelAndWpfButtonGrid}"
                                                Placement="Left">
                                            <StackPanel x:Name="DummySocMedStackPanel"
                                                        Padding="10,6"
                                                        Background="Transparent"
                                                        PointerExited="HideSocMedFlyout"
                                                        Tag="{Binding ElementName=SocMedFlyout}">
                                                <!--  START: SocialMediaParentPanel_QR  -->
                                                <StackPanel Margin="4,8,4,0"
                                                            Visibility="{Binding QrImage.ImageUrl, Converter={StaticResource NullableVisibilityConverter}}">
                                                    <Grid Margin="0,0,0,8"
                                                          Background="White"
                                                          CornerRadius="5"
                                                          Shadow="{ThemeResource SharedShadow}"
                                                          Translation="0,0,16">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <imageex:ImageEx Grid.Row="0"
                                                                         Width="160"
                                                                         Margin="4"
                                                                         HorizontalAlignment="Center"
                                                                         EnableLazyLoading="True"
                                                                         IsCacheEnabled="True"
                                                                         Source="{Binding QrImage.ImageUrl, FallbackValue={x:Null}, Converter={StaticResource UrlToCachedImagePathConverter}}" />
                                                        <TextBlock Grid.Row="1"
                                                                   Margin="0,0,0,8"
                                                                   HorizontalAlignment="Center"
                                                                   FontWeight="Bold"
                                                                   Foreground="Black"
                                                                   Text="{Binding QrDescription}"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap"
                                                                   Visibility="{Binding QrDescription, Converter={StaticResource NullableVisibilityConverter}}" />
                                                    </Grid>
                                                </StackPanel>

                                                <!--  START: SocialMediaParentPanel_Links  -->
                                                <StackPanel Margin="0,2"
                                                            Visibility="{Binding ChildrenLinks, Converter={StaticResource CountToVisibilityConverter}}">
                                                    <ItemsControl ItemsSource="{Binding ChildrenLinks}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="hypTypes:HypLauncherMediaContentData">
                                                                <Button MinWidth="160"
                                                                        Margin="0,2"
                                                                        HorizontalAlignment="Stretch"
                                                                        HorizontalContentAlignment="Stretch"
                                                                        extension:UIElementExtensions.CursorType="Hand"
                                                                        Click="OpenSocMedLink"
                                                                        CornerRadius="5"
                                                                        PointerEntered="ElementScaleOutHoveredPointerEntered"
                                                                        PointerExited="ElementScaleInHoveredPointerExited"
                                                                        Shadow="{ThemeResource SharedShadow}"
                                                                        Style="{ThemeResource AcrylicSemiButtonStyle}"
                                                                        Tag="{Binding ClickLink}"
                                                                        Translation="0,0,8">
                                                                    <Grid Margin="0,0,0,0"
                                                                          HorizontalAlignment="Stretch">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0"
                                                                                   HorizontalAlignment="Left"
                                                                                   VerticalAlignment="Center"
                                                                                   FontWeight="Medium"
                                                                                   HorizontalTextAlignment="Left"
                                                                                   Text="{Binding Title}" />
                                                                        <Grid Grid.Column="1"
                                                                              Margin="4,0,0,0"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"
                                                                              RenderTransformOrigin="0.5, 0.5">
                                                                            <Grid.RenderTransform>
                                                                                <RotateTransform Angle="-90" />
                                                                            </Grid.RenderTransform>
                                                                            <AnimatedIcon Width="14"
                                                                                          HorizontalAlignment="Center"
                                                                                          VerticalAlignment="Center">
                                                                                <animatedvisuals:AnimatedChevronDownSmallVisualSource />
                                                                                <AnimatedIcon.FallbackIconSource>
                                                                                    <FontIconSource FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                                                    Foreground="{ThemeResource ComboBoxDropDownGlyphForeground}"
                                                                                                    Glyph="&#xE70D;" />
                                                                                </AnimatedIcon.FallbackIconSource>
                                                                            </AnimatedIcon>
                                                                        </Grid>
                                                                    </Grid>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </StackPanel>
                                            <Flyout.FlyoutPresenterStyle>
                                                <Style TargetType="FlyoutPresenter">
                                                    <Setter Property="Margin" Value="3,0,0,0" />
                                                    <Setter Property="CornerRadius" Value="5" />
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="MinHeight" Value="0" />
                                                    <Setter Property="MinWidth" Value="0" />
                                                </Style>
                                            </Flyout.FlyoutPresenterStyle>
                                        </Flyout>
                                    </Button.Flyout>

                                    <animations:Explicit.Animations>
                                        <animations:AnimationSet x:Name="SocMedIconPointerEntered">
                                            <animations:OffsetDropShadowAnimation To="0, 2, 0"
                                                                                  Duration="0:0:.25" />
                                            <animations:OpacityDropShadowAnimation To=".5"
                                                                                   Duration="0:0:.25" />
                                            <animations:BlurRadiusDropShadowAnimation To="10"
                                                                                      Duration="0:0:.25" />
                                        </animations:AnimationSet>
                                        <animations:AnimationSet x:Name="SocMedIconPointerExited">
                                            <animations:OffsetDropShadowAnimation To="0, 0, 0"
                                                                                  Duration="0:0:.25" />
                                            <animations:OpacityDropShadowAnimation To="0"
                                                                                   Duration="0:0:.25" />
                                            <animations:BlurRadiusDropShadowAnimation To="0"
                                                                                      Duration="0:0:.25" />
                                        </animations:AnimationSet>
                                    </animations:Explicit.Animations>

                                    <interactivity:Interaction.Behaviors>
                                        <interactivity:EventTriggerBehavior EventName="PointerExited">
                                            <behaviors:StartAnimationAction Animation="{Binding ElementName=SocMedIconPointerExited}" />
                                        </interactivity:EventTriggerBehavior>
                                        <interactivity:EventTriggerBehavior EventName="PointerEntered">
                                            <behaviors:StartAnimationAction Animation="{Binding ElementName=SocMedIconPointerEntered}" />
                                        </interactivity:EventTriggerBehavior>
                                    </interactivity:Interaction.Behaviors>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
            <c:NonFaultyGrid x:Name="WpfPackageParentGrid"
                             Grid.Row="1"
                             Width="50"
                             Height="50"
                             DataContext="{x:Bind WpfContext}"
                             Visibility="{Binding IsWpfPackageEnabled, Converter={StaticResource BooleanVisibilityConverter}}">
                <c:NonFaultyButton x:Name="WpfPackageBtn"
                                   Padding="0"
                                   HorizontalAlignment="Right"
                                   extension:UIElementExtensions.UniformCornerRadius="-1"
                                   BorderThickness="0"
                                   Click="WpfPackageBtn_OnClick"
                                   FlyoutBase.AttachedFlyout="{x:Bind WpfPackageBtnFlyout}"
                                   Loaded="WpfPackageBtn_OnLoaded"
                                   PointerEntered="WpfPackageBtn_OnPointerEntered"
                                   PointerExited="WpfPackageBtn_OnPointerExited">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Name="WpfPackageBtnToolTip"
                                 Opened="WpfPackageBtnToolTip_OnOpened"
                                 Tag="{x:Bind WpfPackageBtn}"
                                 Visibility="Collapsed" />
                    </ToolTipService.ToolTip>
                    <c:NonFaultyButton.Resources>
                        <Flyout x:Name="WpfPackageBtnFlyout"
                                OverlayInputPassThroughElement="{Binding ElementName=SocMedPanelAndWpfButtonGrid}"
                                Placement="LeftEdgeAlignedBottom">
                            <c:NonFaultyGrid x:Name="WpfPackageBtnFlyoutGrid"
                                             MaxWidth="300"
                                             Margin="-16"
                                             Padding="16"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Stretch"
                                             Background="Transparent"
                                             PointerExited="WpfPackageBtnFlyoutGrid_OnPointerExited">
                                <c:NonFaultyGrid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition />
                                </c:NonFaultyGrid.RowDefinitions>
                                <c:NonFaultyStackPanel Grid.Row="0">
                                    <c:NonFaultyImageEx MaxWidth="72"
                                                        EnableLazyLoading="True"
                                                        IsCacheEnabled="True"
                                                        Source="{Binding WpfPackageIconUrl, Converter={StaticResource UrlToCachedImagePathConverter}}" />
                                    <TextBlock MaxWidth="110"
                                               Margin="0,8,0,0"
                                               FontSize="14"
                                               Text="{Binding WpfPackageNameLocalized}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap" />
                                    <TextBlock MaxWidth="110"
                                               Margin="0,0,0,0"
                                               extension:TextBlockExtension.PreserveSpace="False"
                                               extension:TextBlockExtension.RemoveEmptyRuns="True"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Opacity=".5"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap">
                                        <Run Text="v" />
                                        <Run Text="{Binding CurrentInstalledVersion, Mode=OneWay}" />
                                    </TextBlock>
                                </c:NonFaultyStackPanel>
                                <MenuFlyoutSeparator Grid.Row="1"
                                                     Width="64"
                                                     Margin="8,12" />
                                <c:NonFaultyGrid Grid.Row="2"
                                                 Margin="0,0,0,8"
                                                 Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanVisibilityConverter}, Mode=OneWay}">
                                    <c:NonFaultyButton x:Name="WpfPackageStartUpdateBtn"
                                                       HorizontalAlignment="Center"
                                                       Background="{ThemeResource SystemFillColorCautionBrush}"
                                                       Click="WpfPackageStartUpdateBtn_OnClick"
                                                       CornerRadius="12"
                                                       Style="{ThemeResource TransparentDefaultButtonStyle}"
                                                       Visibility="{Binding ChangesInProgress, Converter={StaticResource InverseBooleanVisibilityConverter}, Mode=OneWay}">
                                        <c:NonFaultyGrid Margin="4,0"
                                                         ColumnSpacing="8">
                                            <c:NonFaultyGrid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                            </c:NonFaultyGrid.ColumnDefinitions>
                                            <FontIcon Grid.Column="1"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"
                                                      FontSize="14"
                                                      Glyph="&#xF0C5;" />
                                            <TextBlock Grid.Column="0"
                                                       Margin="0,-1,0,0"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Text="{x:Bind helper:Locale.Current.Lang._WpfPackageContext.StartUpdateBtn, Mode=OneWay}" />
                                        </c:NonFaultyGrid>
                                    </c:NonFaultyButton>
                                </c:NonFaultyGrid>
                                <c:NonFaultyGrid Grid.Row="2"
                                                 MinWidth="260"
                                                 Margin="0,0,0,8"
                                                 Padding="8"
                                                 HorizontalAlignment="Stretch"
                                                 VerticalAlignment="Bottom"
                                                 Background="{ThemeResource GameSettingsBtnBrush}"
                                                 CornerRadius="4"
                                                 RowSpacing="8"
                                                 Visibility="{Binding ChangesInProgress, Converter={StaticResource BooleanVisibilityConverter}, Mode=OneWay}">
                                    <c:NonFaultyGrid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="Auto" />
                                    </c:NonFaultyGrid.ColumnDefinitions>
                                    <c:NonFaultyGrid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </c:NonFaultyGrid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Margin="2,0"
                                               extension:TextBlockExtension.PreserveSpace="False"
                                               extension:TextBlockExtension.RemoveEmptyRuns="True"
                                               FontSize="12">
                                        <Run Text="{Binding Progress.ProgressAllSizeCurrent, Converter={StaticResource FileSizeToStringLiteralConverter}, Mode=OneWay}" />
                                        <Run FontSize="9"
                                             Text=" / " />
                                        <Run FontSize="9"
                                             FontWeight="Bold"
                                             Text="{Binding Progress.ProgressAllSizeTotal, Converter={StaticResource FileSizeToStringLiteralConverter}, Mode=OneWay}" />
                                        <Run FontSize="9"
                                             FontWeight="Bold"
                                             Text=" (" />
                                        <Run FontSize="9"
                                             FontWeight="Bold"
                                             Text="{Binding Progress.ProgressAllSpeed, Converter={StaticResource FileSizeToStringLiteralConverter}, Mode=OneWay}" />
                                        <Run FontSize="9"
                                             FontWeight="Bold"
                                             Text="/s" />
                                        <Run FontSize="9"
                                             FontWeight="Bold"
                                             Text=")" />
                                    </TextBlock>
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Margin="2,0"
                                               HorizontalAlignment="Right"
                                               extension:TextBlockExtension.PreserveSpace="False"
                                               extension:TextBlockExtension.RemoveEmptyRuns="True"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               HorizontalTextAlignment="Right"
                                               Text="{Binding Progress.ProgressAllPercentage, Mode=OneWay, Converter={StaticResource PercentageValueConverter}}"
                                               TextAlignment="Right" />
                                    <c:NonFaultyProgressBar Grid.Row="1"
                                                            Grid.Column="0"
                                                            Grid.ColumnSpan="2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Bottom"
                                                            IsIndeterminate="{Binding Status.IsProgressAllIndetermined, Mode=OneWay}"
                                                            Maximum="100"
                                                            Minimum="0"
                                                            Value="{Binding Progress.ProgressAllPercentage, Mode=OneWay}" />
                                    <c:NonFaultyButton x:Name="WpfPackageCancelUpdateBtn"
                                                       Grid.Row="2"
                                                       Grid.Column="0"
                                                       Grid.ColumnSpan="2"
                                                       HorizontalAlignment="Stretch"
                                                       Click="WpfPackageCancelUpdateBtn_OnClick"
                                                       CornerRadius="4"
                                                       Style="{ThemeResource AccentButtonStyle}">
                                        <c:NonFaultyGrid Margin="4,0"
                                                         ColumnSpacing="8">
                                            <c:NonFaultyGrid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                            </c:NonFaultyGrid.ColumnDefinitions>
                                            <FontIcon Grid.Column="1"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"
                                                      FontSize="14"
                                                      Glyph="&#xE711;" />
                                            <TextBlock Grid.Column="0"
                                                       Margin="0,-1,0,0"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Text="{x:Bind helper:Locale.Current.Lang._WpfPackageContext.CancelUpdateBtn, Mode=OneWay}" />
                                        </c:NonFaultyGrid>
                                    </c:NonFaultyButton>
                                </c:NonFaultyGrid>
                                <ItemsControl Grid.Row="3"
                                              Visibility="{Binding ChangesInProgress, Converter={StaticResource InverseBooleanVisibilityConverter}, Mode=OneWay}">
                                    <c:NonFaultyButton x:Name="WpfPackageReinstallBtn"
                                                       Margin="0,-2,0,4"
                                                       Padding="4,4"
                                                       HorizontalAlignment="Center"
                                                       Background="{ThemeResource SystemFillColorCautionBrush}"
                                                       Click="WpfPackageReinstallBtn_OnClick"
                                                       CornerRadius="12"
                                                       Style="{ThemeResource TransparentDefaultButtonStyle}"
                                                       Visibility="{Binding IsUpdateAvailable, Converter={StaticResource InverseBooleanVisibilityConverter}, Mode=OneWay}">
                                        <c:NonFaultyGrid Margin="4,0"
                                                         ColumnSpacing="4">
                                            <c:NonFaultyGrid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                            </c:NonFaultyGrid.ColumnDefinitions>
                                            <FontIcon Grid.Column="1"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"
                                                      FontSize="12"
                                                      Glyph="&#xEC7A;" />
                                            <TextBlock Grid.Column="0"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Center"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Text="{x:Bind helper:Locale.Current.Lang._WpfPackageContext.ReinstallToolBtn, Mode=OneWay}" />
                                        </c:NonFaultyGrid>
                                    </c:NonFaultyButton>
                                </ItemsControl>
                                <c:NonFaultyGrid x:Name="WpfPackageAutoUpdateGrid"
                                                 Grid.Row="4"
                                                 Margin="0,0,0,-4"
                                                 HorizontalAlignment="Center"
                                                 ColumnSpacing="0">
                                    <c:NonFaultyGrid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition />
                                    </c:NonFaultyGrid.ColumnDefinitions>
                                    <ItemsControl Grid.Column="0"
                                                  Width="22"
                                                  Height="22">
                                        <c:NonFaultyCheckBox x:Name="WpfPackageAutoCheckBox"
                                                             Padding="0"
                                                             IsChecked="{Binding IsAutoUpdateEnabled, Mode=TwoWay}">
                                            <c:NonFaultyCheckBox.RenderTransform>
                                                <CompositeTransform ScaleX=".75"
                                                                    ScaleY=".75" />
                                            </c:NonFaultyCheckBox.RenderTransform>
                                        </c:NonFaultyCheckBox>
                                    </ItemsControl>
                                    <TextBlock Grid.Column="1"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               PointerPressed="WpfPackageCheckBoxText_OnPressed"
                                               Text="{x:Bind helper:Locale.Current.Lang._WpfPackageContext.StartUpdateAutomatically, Mode=OneWay}"
                                               TextWrapping="Wrap" />
                                </c:NonFaultyGrid>
                            </c:NonFaultyGrid>
                        </Flyout>
                    </c:NonFaultyButton.Resources>
                    <c:NonFaultyGrid Margin="-1"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     Background="{ThemeResource GameSettingsBtnBrush}"
                                     DataContext="{x:Bind WpfContext}">
                        <c:NonFaultyImageEx Grid.Column="0"
                                            EnableLazyLoading="True"
                                            IsCacheEnabled="True"
                                            Source="{Binding WpfPackageIconUrl, Converter={StaticResource UrlToCachedImagePathConverter}}" />
                        <c:NonFaultyGrid Opacity="{Binding ChangesInProgress, Converter={StaticResource BooleanToOpacityConverter}}">
                            <c:NonFaultyGrid.OpacityTransition>
                                <ScalarTransition Duration="0:0:.5" />
                            </c:NonFaultyGrid.OpacityTransition>
                            <Border Background="{ThemeResource SmokeFillColorCollapseBrush}" />
                            <Border Background="{ThemeResource SmokeFillColorCollapseBrush}"
                                    Opacity=".5" />
                            <c:NonFaultyProgressRing Width="48"
                                                     Height="48"
                                                     Foreground="{ThemeResource AccentColorBrush}"
                                                     IsIndeterminate="{Binding Status.IsProgressAllIndetermined, Mode=OneWay}"
                                                     Maximum="100"
                                                     Minimum="0"
                                                     Value="{Binding Progress.ProgressAllPercentage, Mode=OneWay}" />
                            <TextBlock Margin="0,0,0,2"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       extension:TextBlockExtension.PreserveSpace="False"
                                       extension:TextBlockExtension.RemoveEmptyRuns="True"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       HorizontalTextAlignment="Center"
                                       Text="{Binding Progress.ProgressAllPercentage, Mode=OneWay, Converter={StaticResource PercentageValueConverter}}"
                                       TextAlignment="Center" />
                        </c:NonFaultyGrid>
                    </c:NonFaultyGrid>
                </c:NonFaultyButton>
                <c:NonFaultyGrid x:Name="WpfPackageStatusGrid"
                                 Margin="0,-2,-2,-12"
                                 Padding="6,4"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Background="Orange"
                                 CornerRadius="10"
                                 Shadow="{ThemeResource SharedShadow}"
                                 Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanVisibilityConverter}, Mode=OneWay}">
                    <c:NonFaultyGrid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                    </c:NonFaultyGrid.ColumnDefinitions>
                    <AnimatedVisualPlayer Grid.Column="0"
                                          Height="14"
                                          Margin="-5,-3"
                                          HorizontalAlignment="Center">
                        <lottie:DownloadIcon Foreground="{Binding ElementName=WpfPackageReinstallBtn, Path=Foreground}" />
                    </AnimatedVisualPlayer>
                </c:NonFaultyGrid>
            </c:NonFaultyGrid>
        </c:NonFaultyGrid>
        <Grid x:Name="MultiBackgroundPipsPagerGridHoverArea"
              Grid.Row="0"
              Grid.RowSpan="2"
              Grid.Column="0"
              Grid.ColumnSpan="2"
              MinWidth="250"
              MinHeight="50"
              Margin="0,0,48,0"
              Padding="0,18,0,0"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Background="Transparent"
              PointerEntered="MultiBackgroundPipsPagerGridHoverArea_OnPointerEntered"
