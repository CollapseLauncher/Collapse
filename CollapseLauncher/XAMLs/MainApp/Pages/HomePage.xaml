                      Visibility="{Binding CurrentBackgroundIsVideo, Mode=OneWay, Converter={StaticResource BooleanVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Margin="2,0"
                            Padding="4"
                            extension:UIElementExtensions.CursorType="Hand"
                            Click="BackgroundVideoPlayToggle_OnClick"
                            DataContext="{Binding CurrentBackgroundElement, Mode=OneWay}"
                            Style="{ThemeResource TransparentDefaultButtonStyle}">
                        <Grid>
                            <FontIcon FontSize="12"
                                      Glyph="&#xE768;"
                                      Visibility="{Binding IsVideoPlay, Mode=OneWay, Converter={StaticResource InverseBooleanVisibilityConverter}}" />
                            <FontIcon FontSize="12"
                                      Glyph="&#xE769;"
                                      Visibility="{Binding IsVideoPlay, Mode=OneWay, Converter={StaticResource BooleanVisibilityConverter}}" />
                        </Grid>
                    </Button>
                    <Grid Grid.Column="1"
                          DataContext="{Binding CurrentBackgroundElement, Mode=OneWay}"
                          Visibility="{Binding IsCurrentMediaSeekable, Mode=OneWay, Converter={StaticResource BooleanVisibilityConverter}}">
                        <Grid Width="300"
                              Margin="4,0"
                              VerticalAlignment="Center"
                              ColumnSpacing="10"
                              Visibility="{Binding MediaDuration, Mode=OneWay, Converter={StaticResource TimeSpanMoreThan15SecondsToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       HorizontalTextAlignment="Center"
                                       Text="{Binding MediaDurationPosition, Mode=OneWay, Converter={StaticResource TimeSpanToTimeStampStringConverter}}"
                                       TextAlignment="Center" />
                            <Slider Grid.Column="1"
                                    Margin="0,-8"
                                    Padding="0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    IsThumbToolTipEnabled="False"
