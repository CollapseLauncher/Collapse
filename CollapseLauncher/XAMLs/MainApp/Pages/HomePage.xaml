                                    NextNavigationButtonMode="Visible"
                                    NormalPipButtonStyle="{ThemeResource NewPipsPagerButtonBaseMediumStyle}"
                                    Orientation="Horizontal"
                                    PreviousButtonStyle="{ThemeResource NewPipsPagerPreviousPageButtonMediumStyle}"
                                    PreviousNavigationButtonMode="Visible"
                                    SelectedPipButtonStyle="{ThemeResource NewPipsPagerButtonBaseSelectedMediumStyle}" />
