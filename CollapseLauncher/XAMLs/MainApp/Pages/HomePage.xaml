                                VerticalAlignment="Stretch"
                                extension:UIElementExtensions.CursorType="Hand"
                                CornerRadius="14"
                                Flyout="{StaticResource BackgroundContextMenuFlyout}"
                                Style="{ThemeResource TransparentDefaultButtonStyle}">
                            <AnimatedIcon Width="16"
                                          Height="16"
                                          RenderTransformOrigin=".5, .5">
                                <AnimatedIcon.RenderTransform>
                                    <RotateTransform Angle="-90" />
                                </AnimatedIcon.RenderTransform>
                                <AnimatedIcon.Source>
                                    <animatedvisuals:AnimatedChevronDownSmallVisualSource />
                                </AnimatedIcon.Source>
                            </AnimatedIcon>
                        </Button>
                    </StackPanel>
                </StackPanel>
                <Grid Padding="4"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="{ThemeResource AcrylicComboBoxBackground}"
