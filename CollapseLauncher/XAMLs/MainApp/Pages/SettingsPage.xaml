<!--  ReSharper disable IdentifierTypo  -->
<!--  ReSharper disable UnusedMember.Local  -->
<!--  ReSharper disable Xaml.ConstructorWarning  -->
<!--  ReSharper disable GrammarMistakeInMarkupAttribute  -->
<Page x:Class="CollapseLauncher.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
      xmlns:backgroundManager="using:CollapseLauncher.GameManagement.ImageBackground"
      xmlns:conv="using:CollapseLauncher.Pages"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ext="using:CollapseLauncher.Extension"
      xmlns:extHelper="using:CollapseLauncher.Helper"
      xmlns:helper="using:CollapseLauncher.Helper"
      xmlns:innerConfig="using:Hi3Helper.Shared.Region"
      xmlns:localWindowSize="using:CollapseLauncher.WindowSize"
      xmlns:localeSourceGen="using:Hi3Helper.LocaleSourceGen"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:plugins="using:CollapseLauncher.Plugins"
      Loaded="Page_Loaded"
      NavigationCacheMode="Enabled"
      Unloaded="Page_Unloaded"
      mc:Ignorable="d">
    <Page.Resources>
        <conv:BooleanVisibilityConverter x:Key="BooleanVisibilityConverter" />
        <conv:InverseBooleanVisibilityConverter x:Key="InverseBooleanVisibilityConverter" />
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <conv:DownloadSpeedLimitToStringConverter x:Key="DownloadSpeedLimitToStringConverter" />
        <conv:DownloadChunkSizeToStringConverter x:Key="DownloadChunkSizeToStringConverter" />
        <conv:DoubleFormatter x:Key="DoubleFormatter" />
        <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <conv:GamePluginIconConverter x:Key="GamePluginIconConverter" />
        <conv:ByStringConverter x:Key="ByStringConverter" />
        <conv:BooleanToIsEnabledOpacityConverter x:Key="BooleanToIsEnabledOpacityConverter" />
        <conv:NullableVisibilityConverter x:Key="NullableVisibilityConverter" />
        <conv:RemoveNewLineStringConverter x:Key="RemoveNewLineStringConverter" />
        <conv:FFmpegVideoDecoderModeToIndexConverter x:Key="FFmpegVideoDecoderModeToIndexConverter" />
    </Page.Resources>
    <Grid>
        <ScrollViewer>
            <Grid Margin="32,40,32,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>
                <StackPanel x:Name="MainSettingsPanel"
                            Grid.Column="0"
                            HorizontalAlignment="Left">
                    <TextBlock Margin="0,0,0,16"
                               Style="{ThemeResource TitleLargeTextBlockStyle}"
                               Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.PageTitle, Mode=OneWay}" />
                    <StackPanel x:Name="AppSettings"
                                Margin="0,8"
                                HorizontalAlignment="Left">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Margin="0,0,0,16"
                                           Style="{ThemeResource SubtitleTextBlockStyle}"
                                           Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.Language, Mode=OneWay}" />
                                <ComboBox x:Name="LanguageSelector"
                                          MinWidth="256"
                                          CornerRadius="14"
                                          ItemsSource="{x:Bind helper:Locale.Current.MetadataList, Mode=OneWay}"
                                          MaxDropDownHeight="400"
                                          SelectedIndex="{x:Bind helper:Locale.Current.LangIndex, Mode=TwoWay}"
                                          SelectionChanged="LanguageSelector_SelectionChanged"
                                          SelectionChangedTrigger="Committed">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="localeSourceGen:LangParamsBase">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="54" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition />
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0"
                                                      Margin="-2,0,8,0"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"
                                                      Background="{ThemeResource NewAccentButtonBackground}"
                                                      CornerRadius="8"
                                                      Translation="0,0,12">
                                                    <TextBlock Margin="6,2"
                                                               HorizontalAlignment="Center"
                                                               FontSize="10"
                                                               FontWeight="Bold"
                                                               Foreground="{ThemeResource NewAccentButtonForeground}"
                                                               HorizontalTextAlignment="Center"
                                                               Text="{Binding LanguageID, Mode=OneWay}"
                                                               TextAlignment="Center" />
                                                </Grid>
                                                <TextBlock x:Name="LanguageName"
                                                           Grid.Column="1"
                                                           Margin="0,0,4,0"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding LanguageName, Mode=OneWay}" />
                                                <TextBlock x:Name="LanguageAuthor"
                                                           Grid.Column="2"
                                                           Margin="6,0,0,0"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           FontSize="11"
                                                           Opacity="0.50"
                                                           Text="{Binding Author, Converter={StaticResource ByStringConverter}, Mode=OneWay}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock x:Name="AppLangSelectionWarning"
                                           Margin="0,12,0,0"
                                           FontWeight="Bold"
                                           Foreground="{ThemeResource AccentColor}"
                                           Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppLang_ApplyNeedRestart, Mode=OneWay}"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed" />
                            </StackPanel>
                            <StackPanel Margin="0,10,0,16">
                                <TextBlock Margin="0,0,0,8"
                                           Style="{ThemeResource SubtitleTextBlockStyle}"
                                           Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppBehavior_Title, Mode=OneWay}" />
                                <TextBlock Margin="0,0,0,10"
                                           Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppBehavior_PostGameLaunch, Mode=OneWay}" />
                                <ComboBox x:Name="GameLaunchedBehaviorSelector"
                                          MinWidth="256"
                                          Margin="0,0,0,14"
                                          CornerRadius="14"
                                          MaxDropDownHeight="200"
                                          SelectedIndex="{x:Bind AppGameLaunchedBehaviorIndex, Mode=TwoWay}">
                                    <ComboBoxItem Content="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppBehavior_PostGameLaunch_Minimize, Mode=OneWay}" />
                                    <ComboBoxItem Content="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppBehavior_PostGameLaunch_ToTray, Mode=OneWay}" />
                                    <ComboBoxItem Content="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppBehavior_PostGameLaunch_Nothing, Mode=OneWay}" />
                                </ComboBox>
                                <ToggleSwitch Margin="0,4"
                                              Header="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppBehavior_MinimizeToTray, Mode=OneWay}"
                                              IsOn="{x:Bind IsMinimizeToTaskbar, Mode=TwoWay}"
                                              OffContent="{x:Bind helper:Locale.Current.Lang._Misc.Disabled, Mode=OneWay}"
                                              OnContent="{x:Bind helper:Locale.Current.Lang._Misc.Enabled, Mode=OneWay}" />
                                <ToggleSwitch x:Name="StartupToggle"
                                              Margin="0,4"
                                              Header="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppBehavior_LaunchOnStartup, Mode=OneWay}"
                                              IsOn="{x:Bind IsLaunchOnStartup, Mode=TwoWay}"
                                              OffContent="{x:Bind helper:Locale.Current.Lang._Misc.Disabled, Mode=OneWay}"
                                              OnContent="{x:Bind helper:Locale.Current.Lang._Misc.Enabled, Mode=OneWay}" />
                                <ToggleSwitch x:Name="StartupToTrayToggle"
                                              Margin="0,4"
                                              Header="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppBehavior_StartupToTray, Mode=OneWay}"
                                              IsOn="{x:Bind IsStartupToTray, Mode=TwoWay}"
                                              OffContent="{x:Bind helper:Locale.Current.Lang._Misc.Disabled, Mode=OneWay}"
                                              OnContent="{x:Bind helper:Locale.Current.Lang._Misc.Enabled, Mode=OneWay}"
                                              Visibility="Collapsed" />
                            </StackPanel>
                            <TextBlock Margin="0,0,0,16"
                                       Style="{ThemeResource SubtitleTextBlockStyle}"
                                       Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppThemes, Mode=OneWay}" />
                            <StackPanel Margin="0,-8,0,8">
                                <RadioButtons x:Name="AppThemeSelection"
                                              Margin="0,0,0,8"
                                              SelectedIndex="{x:Bind CurrentThemeSelection, Mode=TwoWay}">
                                    <RadioButton Content="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppThemes_Default, Mode=OneWay}" />
                                    <RadioButton Content="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppThemes_Light, Mode=OneWay}" />
                                    <RadioButton Content="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppThemes_Dark, Mode=OneWay}" />
                                </RadioButtons>
                                <TextBlock x:Name="AppThemeSelectionWarning"
                                           Margin="0,4"
                                           FontWeight="Bold"
                                           Foreground="{ThemeResource AccentColor}"
                                           Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppThemes_ApplyNeedRestart, Mode=OneWay}"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed" />
                            </StackPanel>
                            <ToggleSwitch Margin="0,4"
                                          Header="{x:Bind helper:Locale.Current.Lang._SettingsPage.IntroSequenceToggle, Mode=OneWay}"
                                          IsOn="{x:Bind IsIntroEnabled, Mode=TwoWay}"
                                          OffContent="{x:Bind helper:Locale.Current.Lang._Misc.Disabled, Mode=OneWay}"
                                          OnContent="{x:Bind helper:Locale.Current.Lang._Misc.Enabled, Mode=OneWay}" />
                            <ToggleSwitch x:Name="AppBackgroundUseAcrylic"
                                          Margin="0,4"
                                          Header="{x:Bind helper:Locale.Current.Lang._SettingsPage.EnableAcrylicEffect, Mode=OneWay}"
                                          IsOn="{x:Bind IsAcrylicEffectEnabled, Mode=TwoWay}"
                                          OffContent="{x:Bind helper:Locale.Current.Lang._Misc.Disabled, Mode=OneWay}"
                                          OnContent="{x:Bind helper:Locale.Current.Lang._Misc.Enabled, Mode=OneWay}" />
                            <TextBlock Margin="0,16,0,8"
                                       Style="{ThemeResource SubtitleTextBlockStyle}"
                                       Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppBG, Mode=OneWay}" />
                            <TextBlock x:Name="RegionalBGNotice"
                                       MaxWidth="400"
                                       Margin="0,0,0,8"
                                       HorizontalAlignment="Left"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource AccentColor}"
                                       Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppBG_Note_Regional, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords"
                                       Visibility="Visible" />
                            <ToggleSwitch x:Name="AppBGMode"
                                          Margin="0,4,0,8"
                                          DataContext="{x:Bind backgroundManager:ImageBackgroundManager.Shared}"
                                          Header="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppBG_Checkbox, Mode=OneWay}"
                                          IsOn="{Binding GlobalIsEnableCustomImage, Mode=TwoWay}"
                                          OffContent="{x:Bind helper:Locale.Current.Lang._Misc.Disabled, Mode=OneWay}"
                                          OnContent="{x:Bind helper:Locale.Current.Lang._Misc.Enabled, Mode=OneWay}" />
                            <StackPanel x:Name="AppBGCustomizer"
                                        Margin="0,4,0,8"
                                        DataContext="{x:Bind backgroundManager:ImageBackgroundManager.Shared}"
                                        Visibility="{Binding GlobalIsEnableCustomImage, Mode=OneWay, Converter={StaticResource BooleanVisibilityConverter}}">
                                <StackPanel Margin="-2,4,0,8"
                                            Orientation="Horizontal">
                                    <Button x:Name="BGSelector"
                                            Height="35"
                                            Margin="-40,0,0,0"
                                            Click="SelectBackgroundImg"
                                            CornerRadius="0,16,16,0"
                                            Style="{ThemeResource AccentButtonStyle}">
                                        <StackPanel Margin="32,0,0,0"
                                                    Orientation="Horizontal">
                                            <FontIcon FontFamily="{ThemeResource FontAwesome}"
                                                      FontSize="22"
                                                      Glyph="&#xF03E;" />
                                            <TextBlock Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontWeight="Medium"
                                                       Text="{x:Bind helper:Locale.Current.Lang._Misc.Select, Mode=OneWay}" />
                                        </StackPanel>
                                    </Button>
                                    <ScrollViewer x:Name="BGPathDisplayViewer"
                                                  Width="{x:Bind localWindowSize:WindowSize.CurrentWindowSize.SettingsPanelWidth}"
                                                  Margin="12,-4,0,-4"
                                                  HorizontalScrollBarVisibility="Visible"
                                                  HorizontalScrollMode="Enabled"
                                                  VerticalScrollMode="Disabled">
                                        <TextBlock x:Name="BGPathDisplay"
                                                   Margin="0,4"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding GlobalCustomBackgroundImagePath, Mode=OneWay}" />
                                    </ScrollViewer>
                                </StackPanel>
                                <TextBlock x:Name="AppBGCustomizerNote"
                                           Width="368"
                                           Margin="0,12,0,0"
                                           HorizontalAlignment="Left"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{ThemeResource AccentColor}"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed" />
                            </StackPanel>
                            <StackPanel x:Name="CustomBGImageSettings"
                                        Margin="0,4">
                                <TextBlock Margin="0,0,0,4"
                                           FontSize="16"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                           Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.ImageBackground, Mode=OneWay}" />
                                <Grid Margin="0,4">
                                    <Border Background="Transparent"
                                            ToolTipService.ToolTip="{x:Bind Waifu2XToolTip}"
                                            Visibility="{x:Bind IsWaifu2XUsable, Converter={StaticResource InverseBooleanVisibilityConverter}}" />
                                    <ToggleSwitch x:Name="Waifu2XToggleSwitch"
                                                  IsEnabled="{x:Bind IsWaifu2XUsable}"
                                                  IsOn="{x:Bind IsWaifu2XEnabled, Mode=TwoWay}"
                                                  OffContent="{x:Bind helper:Locale.Current.Lang._Misc.Disabled, Mode=OneWay}"
                                                  OnContent="{x:Bind helper:Locale.Current.Lang._Misc.Enabled, Mode=OneWay}"
                                                  ToolTipService.ToolTip="{x:Bind Waifu2XToolTip}">
                                        <ToggleSwitch.Header>
                                            <StackPanel Loaded="EnableHeaderMouseEvent"
                                                        Orientation="Horizontal">
                                                <TextBlock VerticalAlignment="Center"
                                                           Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.Waifu2X_Toggle, Mode=OneWay}" />
                                                <TextBlock Margin="10,0,0,0"
                                                           VerticalAlignment="Center"
                                                           FontFamily="{ThemeResource FontAwesomeSolid}"
                                                           FontSize="18"
                                                           Opacity="0.25"
                                                           Text="{x:Bind Waifu2XToolTipIcon}" />
                                            </StackPanel>
                                        </ToggleSwitch.Header>
                                    </ToggleSwitch>
                                </Grid>
                            </StackPanel>
                            <StackPanel x:Name="CustomBGVideoSettings"
                                        Margin="0,4"
                                        DataContext="{x:Bind backgroundManager:ImageBackgroundManager.Shared}">
                                <TextBlock Margin="0,0,0,4"
                                           FontSize="16"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                           Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.VideoBackground, Mode=OneWay}" />
                                <ToggleSwitch x:Name="VideoBackgroundIsAudioMute"
                                              Margin="0,4"
                                              Header="{x:Bind helper:Locale.Current.Lang._SettingsPage.VideoBackground_IsEnableAudio, Mode=OneWay}"
                                              IsOn="{Binding GlobalBackgroundAudioEnabled, Mode=TwoWay}"
                                              OffContent="{x:Bind helper:Locale.Current.Lang._Misc.Disabled, Mode=OneWay}"
                                              OnContent="{x:Bind helper:Locale.Current.Lang._Misc.Enabled, Mode=OneWay}" />
                                <TextBlock Margin="0,4"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                           Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.VideoBackground_AudioVolume, Mode=OneWay}" />
                                <Slider x:Name="VideoBackgroundAudioVolumeSlider"
                                        Width="250"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Maximum="100"
                                        Minimum="0"
                                        Style="{ThemeResource FatSliderStyle}"
                                        Value="{Binding GlobalBackgroundAudioVolume, Mode=TwoWay}" />
                                <ToggleSwitch x:Name="VideoCodecUseFfmpeg"
                                              Margin="0,4,0,0"
                                              Header="{x:Bind helper:Locale.Current.Lang._SettingsPage.VideoBackground_UseFFmpeg, Mode=OneWay}"
                                              IsOn="{Binding GlobalIsUseFFmpeg, Mode=TwoWay}"
                                              OffContent="{x:Bind helper:Locale.Current.Lang._Misc.Disabled, Mode=OneWay}"
                                              OnContent="{x:Bind helper:Locale.Current.Lang._Misc.Enabled, Mode=OneWay}" />
                                <Grid HorizontalAlignment="Left"
                                      ColumnSpacing="8"
                                      RowSpacing="16"
                                      Visibility="{Binding ElementName=VideoCodecUseFfmpeg, Path=IsOn, Mode=OneWay, Converter={StaticResource BooleanVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0"
                                                Grid.Column="0"
                                                Grid.ColumnSpan="2"
                                                DataContext="{x:Bind backgroundManager:ImageBackgroundManager.Shared}"
                                                Orientation="Horizontal"
                                                Spacing="4">
                                        <TextBlock Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.VideoBackground_FFmpegInstallStatus, Mode=OneWay}" />
                                        <TextBlock FontWeight="Bold"
                                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                                   Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.VideoBackground_FFmpegInstallStatus_Installed, Mode=OneWay}"
                                                   Visibility="{Binding GlobalIsFFmpegAvailable, Mode=OneWay, Converter={StaticResource BooleanVisibilityConverter}}" />
                                        <TextBlock FontWeight="Bold"
                                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                   Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.VideoBackground_FFmpegInstallStatus_NotInstalled, Mode=OneWay}"
                                                   Visibility="{Binding GlobalIsFFmpegAvailable, Mode=OneWay, Converter={StaticResource InverseBooleanVisibilityConverter}}" />
                                        <TextBlock Text="-"
                                                   Visibility="{Binding GlobalCustomFFmpegPath, Mode=OneWay, Converter={StaticResource NullableVisibilityConverter}}" />
                                        <TextBlock Text="{Binding GlobalCustomFFmpegPath, Mode=OneWay}"
                                                   Visibility="{Binding GlobalCustomFFmpegPath, Mode=OneWay, Converter={StaticResource NullableVisibilityConverter}}" />
                                    </StackPanel>
                                    <Button Grid.Row="1"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            Padding="12,8"
                                            ext:UIElementExtensions.UniformCornerRadius="-1"
                                            Click="FFmpegInstall_StartInstallationWizard"
                                            IsEnabled="{Binding GlobalIsFFmpegCurrentlyUsed, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}"
                                            Style="{ThemeResource AccentButtonStyle}">
                                        <Grid Margin="0,-2,0,0"
                                              HorizontalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid Grid.Column="0"
                                                  HorizontalAlignment="Left">
                                                <TextBlock HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           HorizontalTextAlignment="Left"
                                                           Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.VideoBackground_FFmpegInstallBtn_InstallationWizard, Mode=OneWay}" />
                                            </Grid>
                                            <Grid Grid.Column="1"
                                                  Margin="4,2,0,0"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RenderTransformOrigin="0.5, 0.5">
                                                <Grid.RenderTransform>
                                                    <RotateTransform Angle="-90" />
                                                </Grid.RenderTransform>
                                                <AnimatedIcon Width="16"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center">
                                                    <animatedvisuals:AnimatedChevronDownSmallVisualSource />
                                                    <AnimatedIcon.FallbackIconSource>
                                                        <FontIconSource FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                        Foreground="{ThemeResource ComboBoxDropDownGlyphForeground}"
                                                                        Glyph="&#xE70D;" />
                                                    </AnimatedIcon.FallbackIconSource>
                                                </AnimatedIcon>
                                            </Grid>
                                        </Grid>
                                    </Button>
                                    <StackPanel Grid.Row="2"
                                                Grid.Column="0"
                                                Grid.ColumnSpan="2"
                                                Spacing="8">
                                        <Grid MaxWidth="480"
                                              Padding="12"
                                              HorizontalAlignment="Left"
                                              Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                              ColumnSpacing="8"
                                              CornerRadius="4"
                                              RowSpacing="4"
                                              Visibility="{Binding GlobalIsFFmpegCurrentlyUsed, Mode=OneWay, Converter={StaticResource BooleanVisibilityConverter}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition />
                                            </Grid.RowDefinitions>
                                            <FontIcon Grid.Row="0"
                                                      Grid.Column="0"
                                                      FontSize="16"
                                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                      Glyph="&#xEB90;" />
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="1"
                                                       FontWeight="Bold"
                                                       Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.VideoBackground_FFmpegInstallLockedTitle, Mode=OneWay}" />
                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="0"
                                                       Grid.ColumnSpan="2"
                                                       FontSize="12"
                                                       Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.VideoBackground_FFmpegInstallLockedContent, Mode=OneWay}"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                        <Grid MaxWidth="480"
                                              Padding="12"
                                              HorizontalAlignment="Left"
                                              Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                              ColumnSpacing="8"
                                              CornerRadius="4"
                                              RowSpacing="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition />
                                            </Grid.RowDefinitions>
                                            <FontIcon Grid.Row="0"
                                                      Grid.Column="0"
                                                      FontSize="16"
                                                      Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                      Glyph="&#xE814;" />
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="1"
                                                       FontWeight="Bold"
                                                       Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.VideoBackground_FFmpegInstallNote, Mode=OneWay}" />
                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="0"
                                                       Grid.ColumnSpan="2"
                                                       FontSize="12"
                                                       Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.VideoBackground_FFmpegInstallNoteContent, Mode=OneWay}"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                                <ComboBox x:Name="VideoCodecFfmpegDecodingMethod"
                                          CornerRadius="14"
                                          IsEnabled="{Binding GlobalIsFFmpegAvailable, Mode=OneWay}"
                                          ItemsSource="{x:Bind FFmpegDecodingModeSelectionItems, Mode=OneWay}"
                                          Margin="0,8,0,0"
                                          Visibility="{Binding ElementName=VideoCodecUseFfmpeg, Path=IsOn, Mode=OneWay, Converter={StaticResource BooleanVisibilityConverter}}"
                                          SelectedIndex="{Binding GlobalFFmpegDecodingMode, Mode=TwoWay, Converter={StaticResource FFmpegVideoDecoderModeToIndexConverter}}">
                                    <ComboBox.Header>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <TextBlock Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.VideoBackground_FFmpegVideoDecodingMethod, Mode=OneWay}"/>
                                            <Button Width="24"
                                                    Height="24"
                                                    Padding="0"
                                                    CornerRadius="4"
                                                    Style="{ThemeResource AcrylicButtonStyle}">
                                                <Button.Content>
                                                    <FontIcon FontFamily="{ThemeResource FontAwesome}"
                                                              FontSize="10"
                                                              Glyph="&#x3f;" />
                                                </Button.Content>
                                                <Button.Flyout>
                                                    <Flyout Placement="Right">
                                                        <ItemsRepeater ItemsSource="{x:Bind FFmpegDecodingModeHelpItems, Mode=OneWay}"
                                                                       Margin="0,-8"/>
                                                    </Flyout>
                                                </Button.Flyout>
                                            </Button>
                                        </StackPanel>
                                    </ComboBox.Header>
                                </ComboBox>
                            </StackPanel>
                            <TextBlock Margin="0,16,0,8"
                                       Style="{ThemeResource SubtitleTextBlockStyle}"
                                       Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppWindowSize, Mode=OneWay}" />
                            <StackPanel Margin="0,0,0,8">
                                <RadioButtons x:Name="WindowSizeSelection"
                                              MaxColumns="2"
                                              SelectedIndex="{x:Bind SelectedWindowSizeProfile, Mode=TwoWay}">
                                    <StackPanel Margin="0,-1,0,0"
                                                Orientation="Horizontal">
                                        <TextBlock FontFamily="{ThemeResource FontAwesomeSolid}"
                                                   FontSize="22"
                                                   Text="&#xf065;" />
                                        <TextBlock Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Medium"
                                                   Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppWindowSize_Normal, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,-1,0,0"
                                                Orientation="Horizontal">
                                        <TextBlock FontFamily="{ThemeResource FontAwesomeSolid}"
                                                   FontSize="22"
                                                   Text="&#xf066;" />
                                        <TextBlock Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Medium"
                                                   Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.AppWindowSize_Small, Mode=OneWay}" />
                                    </StackPanel>
                                </RadioButtons>
                            </StackPanel>
                            <TextBlock Margin="0,16,0,8"
                                       Style="{ThemeResource SubtitleTextBlockStyle}"
                                       Text="{x:Bind helper:Locale.Current.Lang._SettingsPage.KbShortcuts_Title, Mode=OneWay}" />
                            <ToggleSwitch Margin="0,4"
                                          IsOn="{x:Bind AreShortcutsEnabled, Mode=TwoWay}"
