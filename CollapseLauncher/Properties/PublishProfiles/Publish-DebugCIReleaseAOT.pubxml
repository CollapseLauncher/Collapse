<?xml version="1.0" encoding="utf-8"?>
<!--
https://go.microsoft.com/fwlink/?LinkID=208121.
-->
<Project>
    <PropertyGroup>
        <!-- Configuration and Platform -->
        <Configuration>Debug</Configuration>
        <Platform>x64</Platform>

        <!-- Publish Directory and Protocol -->
        <PublishDir>..\..\CollapseLauncher-ReleaseRepo\preview-ci-build</PublishDir>
        <PublishProtocol>FileSystem</PublishProtocol>

        <!-- Target Framework and Runtime Identifier -->
        <TargetFramework>net10.0-windows10.0.26100.0</TargetFramework>
        <RuntimeIdentifier>win-x64</RuntimeIdentifier>

        <!-- Publish Options -->
        <PublishAot>true</PublishAot>

        <!-- Compilation and Optimization -->
        <!--
        NativeAOT: Must set Optimize=true to avoid a GC reentrancy deadlock
        caused by FindReferenceTargetsCallback .cctor being triggered during GC
        in non-optimized builds.
        See: https://github.com/dotnet/runtime/pull/121558
        This can be reverted to Optimize=false once the project is upgraded to .NET 11.
        -->
        <Optimize>true</Optimize>

        <!-- Debugging and Metadata -->
        <DebuggerSupport>true</DebuggerSupport>
        <TrimmerRemoveSymbols>false</TrimmerRemoveSymbols>
        <IlcGenerateMstatFile>true</IlcGenerateMstatFile>
        <IlcGenerateDgmlFile>true</IlcGenerateDgmlFile>

        <!-- Security and Resource Management -->
        <MetricsSupport>true</MetricsSupport>
        <XmlResolverIsNetworkingEnabledByDefault>false</XmlResolverIsNetworkingEnabledByDefault>

        <!-- Runtime Patch -->
        <TargetLatestRuntimePatch>true</TargetLatestRuntimePatch>
    </PropertyGroup>
</Project>